#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *head=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    head = new Node;
    head->data = A[0];
    head->next = head;
    last = head;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=last->next;
        last->next = temp;
        last=temp;
    }
    
}

void Display(struct Node* p)
{
    do
    {
        cout<<p->data<<"->";
        p=p->next;
        
    } while(p!=head);
    cout<<endl;
}

int main()
{
    int A[]={10,20,30,40,50};
    Create(A,5);
    Display(head);

    return 0;
}
