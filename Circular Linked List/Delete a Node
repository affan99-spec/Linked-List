#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *head=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    head = new Node;
    head->data = A[0];
    head->next = head;
    last = head;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=last->next;
        last->next = temp;
        last=temp;
    }
    
}

void Display(struct Node* p)
{
    do
    {
        cout<<p->data<<"->";
        p=p->next;
        
    } while(p!=head);
    cout<<endl;
}

int Length(struct Node *p)
{
    int len=0;
    do
    {
        len++;
        p=p->next;
    } while(p!=head);
    return len;
}

int Delete(struct Node *p,int pos)
{
    struct Node *q=0;
    int i, x;
    
    if(pos<0 || pos>Length(head))
        return -1;
    
    if(pos==1)
    {
        while(p->next != head)
            p=p->next;
        x=head->data;
        if(head==p)
        {
            delete head;
            head=0;
        }
        else
        {
            p->next=head->next;
            delete head;
            head=p->next;
        }
    }
    else
    {
        p=head;
        for(i=0; i<pos-2; i++)
            p=p->next;
        q=p->next;
        p->next=q->next;
        x=q->data;
        delete q;
    }
    return x;
}

int main()
{
    int A[]={10,20,30,40,50};
    Create(A,5);
    cout<<"Deleted Node is\n";
    cout<<Delete(head,3)<<endl;
    Display(head);

    return 0;
}
