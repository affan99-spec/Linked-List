#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

void removeDuplicate(struct Node *p)
{
    struct Node *q;
    p=first;
    q=first->next;
    while(q != 0)
    {
        if(p->data != q->data)
        {
            p=q;
            q=q->next;
        }
        else
        {
            p->next=q->next;
            delete q;
            q=p->next;
        }
    }
}

void Display(struct Node* p)
{
    while(p != 0)
    {
        cout<<p->data<<"->";
        p=p->next;
    }
    cout<<endl;
}
 
int main()
{
    int A[]={10,10,20,20,20,30,40,40,50,50};
    Create(A,10);
    removeDuplicate(first);
    Display(first);

    return 0;
}
