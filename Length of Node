#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

void Display(struct Node* p)
{
    if(p != 0)
    {
        cout<<p->data<<"->";
        Display(p->next);
    }
}

// Iterative Function of counting Node //
int Count(struct Node *p)
{
    int c=0;
    while(p != 0)
    {
        c++;
        p=p->next;
    }
    return c;
}

// Recursive Function of Count the Node // 
int RCount(struct Node *p)
{
    if(p==0)
        return 0;
    return 1+RCount(p->next);
}

int main()
{
    int A[]={3,5,7,10,15};
    Create(A, 5);
    cout<<"Length of Node is "<<Count(first)<<endl;
    cout<<"Length of Node is "<<RCount(first)<<endl;
    Display(first);

    return 0;
}
