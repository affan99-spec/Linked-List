#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

void Display(struct Node* p)
{
    while(p != 0)
    {
        cout<<p->data<<"->";
        p=p->next;
    }
    cout<<endl;
}

int isLoop(struct Node *first)
{
    struct Node *p, *q;
    p=q=first;
    do
    {
        p=p->next;
        q=q->next;
        q=q!=NULL ? q->next:NULL;
    } while(p && q && p!=q);
    if(p==q)
        return 1;
    return 0;
}

int main()
{
    struct Node *t1, *t2;
    int A[]={10,20,30,40,50};
    Create(A,5);
    t1=first->next->next;
    t2=first->next->next->next->next;
    t2->next=t1;
    
    if(isLoop(first))
        cout<<"It is a Circular Linked List\n";
    else 
        cout<<"It is a Linear Linked List\n";
    return 0;
}
