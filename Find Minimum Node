#include <iostream>
#include<climits>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

void Display(struct Node* p)
{
    if(p != 0)
    {
        cout<<p->data<<"->";
        Display(p->next);
    }
}

// Iterative Function for Minimim Node //
int Min(struct Node *p)
{
    int m = INT_MAX;
    while(p)
    {
        if(p->data < m)
            m=p->data;
        p=p->next;
    }
    return m;
}

// Recursive Function for Minimum Node // 
int RMin(struct Node *p)
{
    int x=0;
    if(p==0)
        return INT_MAX;
    x=RMin(p->next);
    return x<p->data ? x:p->data;
}

// Recursive Function for Minimum Node //
int RRMin(struct Node *p)
{
    int x=0;
    if(p==0)
    {
        return INT_MAX;
    }
    else
    {
        x=RRMin(p->next);
        if(x<p->data)
            return x;
        else
            return p->data;
    }
    return x;
}

int main()
{
    int A[]={3,85,37,10,1,28,12,18,2};
    Create(A, 9);
    cout<<"Minimum of the Node is "<<Min(first)<<endl;
    cout<<"Minimum of the Node is "<<RMin(first)<<endl;
    cout<<"Minimum of the Node is "<<RRMin(first)<<endl;
    Display(first);

    return 0;
}
