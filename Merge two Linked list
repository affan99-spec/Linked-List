#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL, *second=NULL, *third=NULL;

void Create1(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

