}

void Merge(struct Node *p,struct Node *q)
{
    struct Node *last;
    if(p->data < q->data)
    {
        third=last=p;
        p=p->next;
        last->next=0;
    }
    else
    {
        third=last=q;
        q=q->next;
        last->next=0;
    }
    while(p && q)
    {
        if(p->data < q->data)
        {
            last->next=p;
            last=p;
            p=p->next;
            last->next=0;
        }
        else
        {
            last->next=q;
            last=q;
            q=q->next;
            last->next=0;
        }
    }
    if(p)
    {
        last->next=p;
    }
    else
    {
        last->next=q;
    }
}

