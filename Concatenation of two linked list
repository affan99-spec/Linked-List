void Display(struct Node* p)
{
    while(p != 0)
    {
        cout<<p->data<<"->";
        p=p->next;
    }
    cout<<endl;
}

void Concat(struct Node *p,struct Node *q)
{
    while(p->next!=0)
    {
        p=p->next;
    }
    p->next=q;
    q=0;
}

