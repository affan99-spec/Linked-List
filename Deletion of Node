#include <iostream>

using namespace std;

struct Node
{
    int data;
    struct Node *next;
};

struct Node *first=NULL;

void Create(int A[],int n)
{
    int i;
    struct Node *temp, *last;
    first = new Node;
    first->data = A[0];
    first->next = 0;
    last = first;
    
    for(i=1; i<n; i++)
    {
        temp=new Node;
        temp->data=A[i];
        temp->next=0;
        last->next = temp;
        last=temp;
    }
    
}

int Delete(struct Node *p,int pos)
{
    struct Node *q=0;
    int x=-1,i;
    if(pos == 1)
    {
        p=first;
        x=first->data;
        first=first->next;
        delete p;
        return x;
    }
    else
    {
        p=first;
        q=0;
        for(i=0; i<pos-1 && p; i++)
        {
            q=p;
            p=p->next;
        }
        if(p)
        {
            q->next=p->next;
            x=p->data;
            delete p;
            return x;
        }
    }
    return 0;
}

void Display(struct Node* p)
{
    while(p != 0)
    {
        cout<<p->data<<"->";
        p=p->next;
    }
    cout<<endl;
}

int main()
{
    int A[]={10,20,30,40,50};
    Create(A,5);
    cout<<"Deleted element is "<<Delete(first,1)<<endl; // Delete at first Node //
    Display(first);
    cout<<endl;
    cout<<"Deleted element is "<<Delete(first,3)<<endl; // Delete at 3th Node //
    Display(first);

    return 0;
}
